# 1. Берем готовый контейнер с установленным языком Node.js версии 20
FROM node:20-alpine

# 2. Создаем внутри контейнера рабочую папку /app
WORKDIR /app

# 3. Копируем наш файл server.js с компьютера внутрь контейнера
COPY server.js .

# 4. Говорим контейнеру, какую команду выполнить при старте
CMD ["node", "server.js"]

